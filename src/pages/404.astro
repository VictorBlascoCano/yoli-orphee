---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDictionary } from "../i18n/utils";

const lang = "es" as const;
const dict = getDictionary(lang);
---

<BaseLayout lang={lang} dict={dict} title="404">
  <div class="mx-auto max-w-xl px-6 py-24 text-center">
    <p class="font-display text-6xl text-plum">404</p>
    <p class="mt-4 text-lg text-ink-soft">
      Página no encontrada · Page not found
    </p>
    <a href="/" class="mt-8 inline-block rounded-full bg-ink px-6 py-3 text-sm font-medium text-paper hover:bg-plum-deep transition-colors">
      Volver al inicio · Back home
    </a>
  </div>
</BaseLayout>
