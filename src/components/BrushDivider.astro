---
/**
 * Signature element of the site: a single hand-drawn brushstroke.
 * Draws itself in once on load (respects prefers-reduced-motion, see global.css).
 */
interface Props {
  class?: string
  animate?: boolean
}
const { class: className = '', animate = true } = Astro.props
---

<svg
  class:list={['w-full h-auto', animate && 'brush-draw', className]}
  viewBox='0 0 600 40'
  fill='none'
  xmlns='http://www.w3.org/2000/svg'
  aria-hidden='true'
>
  <path
    d='M4 24C60 6 110 34 168 20C226 6 268 32 330 22C392 12 430 30 486 18C520 10 552 20 596 14'
    stroke='currentColor'
    stroke-width='5'
    stroke-linecap='round'></path>
</svg>
