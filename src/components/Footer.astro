---
import type { Locale } from '../i18n/config'
import type { Dictionary } from '../i18n/utils'

interface Props {
  lang: Locale
  dict: Dictionary
}
const { dict } = Astro.props
const year = new Date().getFullYear()

const email = "yoliorphee@gmail.com"
const location = "Granollers, Barcelona"

const socials = [
  { label: 'Instagram', href: 'https://www.instagram.com/yoliorphee' },
  { label: 'TikTok', href: 'https://www.tiktok.com/@yoliorphee' }
]

---

<footer class='border-t border-ink/10'>
  <div
    class='mx-auto max-w-5xl px-6 py-10 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between'
  >
    <div>
      <p class='font-display text-lg text-ink'>{dict.meta.siteName}</p>
      <p class='text-sm text-ink-soft mt-1'>{dict.meta.tagline}</p>
      <p class='text-sm text-ink-soft mt-1'><a href={"mailto:" + email}>{email}</a> - {location}</p>
    </div>

    <div class='flex flex-col gap-2 sm:items-end'>
      <p class='font-mono text-xs uppercase tracking-wide text-ink-soft'>
        {dict.footer.social}
      </p>
      <div class='flex gap-4 text-sm'>
        {
          socials.map((s) => (
            <a
              href={s.href}
              class='text-ink-soft hover:text-plum transition-colors'
              rel='me noopener noreferrer'
              target='_blank'
            >
              {s.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <div class='border-t border-ink/10'>
    <p class='mx-auto max-w-5xl px-6 py-4 text-xs text-ink-soft'>
      © {year}{' '}
      {dict.meta.siteName}. {dict.footer.rights}
    </p>
  </div>
</footer>
