---
import BaseLayout from '../layouts/BaseLayout.astro'
import BrushDivider from '../components/BrushDivider.astro'
import { getDictionary, getRoutePath } from '../i18n/utils'
import type { Locale } from '../i18n/config'

interface Props {
  lang: Locale
}
const { lang } = Astro.props
const dict = getDictionary(lang)
---

<BaseLayout lang={lang} dict={dict} title={dict.nav.home}>
  <section class='mx-auto max-w-3xl px-6 pt-16 pb-20 sm:pt-24'>
    <p class='font-mono text-xs uppercase tracking-widest text-plum'>
      {dict.home.eyebrow}
    </p>
    <h1
      class='mt-4 max-w-2xl font-display text-4xl leading-tight text-ink sm:text-5xl whitespace-pre-line'
    >
      {dict.home.title}
    </h1>
    <p class='mt-6 max-w-xl text-lg leading-relaxed text-ink-soft'>
      {dict.home.lead}
    </p>

    <div class='mt-8 flex flex-wrap gap-4'>
      <a
        href={getRoutePath(lang, 'therapies')}
        class='rounded-full bg-ink px-6 py-3 text-sm font-medium text-paper hover:bg-plum-deep transition-colors'
      >
        {dict.home.ctaPrimary}
      </a>
      <a
        href={getRoutePath(lang, 'shop')}
        class='rounded-full border border-ink/20 px-6 py-3 text-sm font-medium text-ink hover:border-plum hover:text-plum transition-colors'
      >
        {dict.home.ctaSecondary}
      </a>
    </div>

    <div class='mt-16 max-w-md text-plum'>
      <BrushDivider />
    </div>
  </section>

  <section class='mx-auto max-w-3xl px-6 pb-24 grid gap-6 sm:grid-cols-2'>
    <a
      href={getRoutePath(lang, 'therapies')}
      class='rounded-2xl border border-ink/10 p-8 hover:border-plum/40 transition-colors'
    >
      <h2 class='font-display text-2xl text-ink'>
        {dict.home.sections.therapiesTitle}
      </h2>
      <p class='mt-3 text-ink-soft leading-relaxed'>
        {dict.home.sections.therapiesText}
      </p>
      <span class='mt-4 inline-block text-sm font-medium text-plum'
        >{dict.home.sections.therapiesLink} →</span
      >
    </a>

    <a
      href={getRoutePath(lang, 'shop')}
      class='rounded-2xl border border-ink/10 p-8 hover:border-plum/40 transition-colors'
    >
      <h2 class='font-display text-2xl text-ink'>
        {dict.home.sections.shopTitle}
      </h2>
      <p class='mt-3 text-ink-soft leading-relaxed'>
        {dict.home.sections.shopText}
      </p>
      <span class='mt-4 inline-block text-sm font-medium text-plum'
        >{dict.home.sections.shopLink} →</span
      >
    </a>
  </section>
</BaseLayout>
